generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    Int             @id @default(autoincrement())
  name                  String
  email                 String          @unique
  passwordHash          String
  role                  Role            @default(ADMIN)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  invoices              Invoice[]
  recordsCreated        InvoiceRecord[] @relation("InvoiceRecordCreatedBy")
  recordsUpdated        InvoiceRecord[] @relation("InvoiceRecordUpdatedBy")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Client {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  invoices  Invoice[]
}

model Broker {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  invoices  Invoice[]
}

model Invoice {
  id            Int            @id @default(autoincrement())
  invoiceNumber String         @unique
  clientId      Int
  client        Client         @relation(fields: [clientId], references: [id])
  brokerId      Int?
  broker        Broker?        @relation(fields: [brokerId], references: [id])
  checkDate     DateTime?
  payrollNumber String?
  premium       Decimal        @default(0) @db.Decimal(12, 2)
  claimPayment  Decimal        @default(0) @db.Decimal(12, 2)
  noOfEmployees Int            @default(0)
  employeeRate  Decimal        @default(7.5) @db.Decimal(12, 2)
  createdById   Int
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  record        InvoiceRecord?

  @@index([clientId])
  @@index([createdById])
  @@index([createdAt])
  @@index([brokerId])
}

model InvoiceRecord {
  id            Int            @id @default(autoincrement())
  invoiceId     Int            @unique
  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  status        InvoiceStatus  @default(Weekly)
  paymentStatus PaymentStatus?
  remarks       String?
  createdById   Int
  createdBy     User           @relation(fields: [createdById], references: [id], name: "InvoiceRecordCreatedBy")
  updatedById   Int?
  updatedBy     User?          @relation(fields: [updatedById], references: [id], name: "InvoiceRecordUpdatedBy")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([createdById])
  @@index([updatedById])
}

enum InvoiceStatus {
  Weekly
  Biweekly
  Monthly
}

enum PaymentStatus {
  ReceivedPayment
  InvoiceReady
  BilledAlready
  InvoiceSent
  InitialBilling
  SampleOnly
  Cancel
  ACH
  CancelAndIssueNew
  PleaseBill
  ACHReturn
  BilledNeedsMonthlyStatement
  BilledButDidntCharge
  FCACH
  CreditCard
}
